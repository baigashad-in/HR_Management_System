
@{
    ViewBag.Title = "AddEmployee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*<h2>AddEmployee</h2>*@

<div class="container-fluid">
    @*<div class="row m-2 p-2 text-center fs-3 "><center> Welcome <b class="textcolor2">Admin</b> </center></div>*@
    <div class="row py-2 ">
        <div class="col-sm-10 mx-auto">
            @*<p class="text-center fs-3"> Add <b class="text-danger">Employee</b></p>*@
            <p class="text-center fs-3"> Add <b class="textcolor2">Employee</b></p>
            <div class="row py-3">
                <div class="col-sm-4">
                    <img src="~/Content/images/employeeimage.jpg" class="img-fluid" />
                </div>
                <div class="col-sm-8">
                    <form method="post">
                        <div class="row">
                            <!--Input Start-->
                            <!-- Employee ID-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingPassword" placeholder="EmployeeId" name="EmployeeIdAttribute">
                                    <label for="floatingPassword">Enter Employee-Id</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <!--Employee Name Start-->
                            <h3 class="fw-light">Personal Details</h3>
                            <div class="col-sm-12">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingPassword" placeholder="FullName" name="EmployeeNameAttribute">
                                    <label for="floatingPassword">Enter Employee Full Name</label>
                                </div>
                            </div>
                            <!--Employee Name End-->
                            <!--Input End-->
                            <!--Gender Start-->
                            <div class="col-sm-6">
                                <span class="fw-medium">Gender</span><br />
                                @*<div class="form-check">*@
                                    <input class="form-check-input" type="radio" name="EmployeeGenderAttribute" id="radioDefault1" value="Male">
                                    <span class="form-check-label" for="radioDefault1">
                                        Male
                                    </span>
                                @*</div>*@
                                @*<div class="form-check">*@
                                    <input class="form-check-input" type="radio" name="EmployeeGenderAttribute" id="radioDefault2" value="Female">
                                    <span class="form-check-label" for="radioDefault2">
                                        Female
                                    </span>
                                @*</div>*@
                            </div>
                            <!--Gender End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="date" class="form-control" id="floatingPassword" placeholder="DateofBirth" name="EmployeeDOBAttribute">
                                    <label for="floatingPassword">Select Employee Date of Birth</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="number" class="form-control" id="floatingPassword" placeholder="ContactNumber" name="EmployeeContactNumberAttribute">
                                    <label for="floatingPassword">Enter Employee Contact Number</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="email" class="form-control" id="floatingPassword" placeholder="Email" name="EmployeePersonalEmailAttribute">
                                    <label for="floatingPassword">Enter Personal Email Id</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="email" class="form-control" id="floatingPassword" placeholder="Email" name="EmployeeOfficialEmailAttribute">
                                    <label for="floatingPassword">Enter Official Email Id</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="number" class="form-control" id="floatingPassword" placeholder="Aadhar" name="EmployeeAadharNumberAttribute">
                                    <label for="floatingPassword">Enter Employee Aadhar Number</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Select Start-->
                            <!--<div class="col-sm-6">
                        <div class="form-floating mb-3">
                            <select class="form-select" id="floatingSelect" aria-label="Floating label select example">
                                <option selected>Techpile</option>
                                <option value="1">One</option>
                                <option value="2">Two</option>
                                <option value="3">Three</option>
                            </select>
                            <label for="floatingSelect">Select Company</label>
                        </div>
                    </div>-->
                            <!--Select End-->
                            <!-- Text Area Start-->
                            <div class="col-sm-12">
                                <div class="mb-3">
                                    @*<label for="exampleFormControlTextarea1" class="form-label">Address</label>*@
                                    <textarea class="form-control" id="exampleFormControlTextarea1" rows="3" name="EmployeeAddressAttribute" placeholder="Address"></textarea>
                                </div>
                            </div>

                            <!-- Text Area End-->

                            <h3 class="fw-lighter">Job Details</h3>
                            <!--Select Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <select class="form-select" id="floatingSelect" aria-label="Floating label select example" name="EmployeeRoleAttribute">
                                        <option selected>-- Select Role --</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Employee">Employee</option>
                                        @*<option value="3">Team Lead</option>
                                    <option value="4">HR</option>
                                    <option value="5">Manager</option>*@
                                    </select>
                                    <label for="floatingSelect">Select Role</label>
                                </div>
                            </div>
                            <!--Select End-->
                            <!--Select Start-->
                            @*<div class="col-sm-6">
                            <div class="form-floating mb-3">
                                <select class="form-select" id="floatingSelect" aria-label="Floating label select example">
                                    <option selected>Techpile</option>
                                    <option value="1">One</option>
                                    <option value="2">Two</option>
                                    <option value="3">Three</option>
                                </select>
                                <label for="floatingSelect">Select Department</label>
                            </div>
                        </div>*@
                            <!--Select End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingPassword" placeholder="Designation" name="EmployeeDesignationAttribute">
                                    <label for="floatingPassword">Enter Employee Designation</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="date" class="form-control" id="floatingPassword" placeholder="DateOfJoining" name="EmployeeDOJAttribute">
                                    <label for="floatingPassword">Select Employee Date of Joining</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <!--<div class="col-sm-6">
                        <div class="form-floating mb-3">
                            <input type="number" class="form-control" id="floatingPassword" placeholder="EmployeeType" name="EmployeeTypeAttribute">
                            <label for="floatingPassword">Salary (per month)</label>
                        </div>
                    </div>-->
                            <!--Input End-->

                            <h3 class="fw-lighter">Account Details</h3>
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingPassword" placeholder="EmployeeWorkingHours" name="EmployeeBankNameAttribute">
                                    <label for="floatingPassword">Bank Name</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="number" class="form-control" id="floatingPassword" placeholder="ReportingManager" name="EmployeeAccountNumberAttribute">
                                    <label for="floatingPassword">Bank Account Number</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingPassword" placeholder="ReportingManager" name="EmployeePANAttribute">
                                    <label for="floatingPassword">PAN Number</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-6">
                                <div class="form-floating mb-3">
                                    <input type="text" class="form-control" id="floatingPassword" placeholder="ReportingManager" name="EmployeeIFSCcodeAttribute">
                                    <label for="floatingPassword">IFSC Code</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <!--Input Start-->
                            <div class="col-sm-12">
                                <div class="form-floating mb-3">
                                    <input type="number" class="form-control" id="floatingPassword" placeholder="ReportingManager" name="EmployeeSalaryAttribute">
                                    <label for="floatingPassword">Salary (per month)</label>
                                </div>
                            </div>
                            <!--Input End-->
                            <div class="col-sm-6">
                                <input type="submit" class="form-control bg-success text-light" value="Add Employee" />
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

