@model System.Data.DataTable
@{
    ViewBag.Title = "AdminLeaveMngmt";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Admin Leave Management</h2>

<div class="container-fluid overflow-auto">
    @Html.AntiForgeryToken()
    <p class="text-center fs-3 mt-3">Leave <b class="textcolor2">Applications</b> </p>
    <hr class="w-25 mx-auto" />

    <!-- Start Tab Buttons-->
    <div class="row d-grid justify-content-center">
        <div class="col-sm-12 shadow-lg p-4 rounded-4">
            <ul class="nav nav-tabs" id="myTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab" aria-controls="home" aria-selected="true">Pending Leaves</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="false">Accepted Leaves</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab" aria-controls="contact" aria-selected="false">Rejected Leaves</button>
                </li>
            </ul>
        </div>
    </div>
    <!-- Start Tab Buttons-->

    @{
        if (Model.Rows.Count > 0)
        {
            <div class="tab-content" id="myTabContent">

                <!-- Start Pending Leaves-->
                <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
                    <div class="row">
                        <div class="col-sm-6">
                            <table class="table" id="mytable">
                                <thead class="table table-bordered table-warning table-hover table-responsive">
                                    <tr>
                                        <th>Sr</th>
                                        <th>EmployeeId</th>
                                        <th>EmployeeName</th>
                                        <th>Leave_Subject</th>
                                        <th>Leave_Details</th>
                                        <th>From_Date</th>
                                        <th>To_Date</th>
                                        <th>Total_Days</th>
                                        <th>Added_On</th>
                                        <th>Admin Status</th>
                                        @*<th>Comment By Admin</th>*@
                                        <th>Action</th>

                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        foreach (System.Data.DataRow item in Model.Rows)
                                        {
                                            //if (item["Leave_Status"].ToString() == "Pending")
                                            if (item["Leave_Status"].ToString().Equals("Pending"))
                                            {
                                                <tr>
                                                    <td>@item["Sr"]</td>
                                                    <td class="td_EmployeeId">@item["EmployeeId"]</td>
                                                    <td>@item["EmployeeName"]</td>
                                                    <td>@item["Leave_Subject"]</td>
                                                    <td>@item["Leave_Details"]</td>
                                                    <td>@item["From_Date"]</td>
                                                    <td>@item["To_Date"]</td>
                                                    <td>@item["Total_Days"]</td>
                                                    <td>@item["Added_On"]</td>
                                                    @*href="/Home/GetLeaveById?OldLeaveId=@item["EmployeeId"]"*@
                                                    @*<td>@item["Status_via_Admin"]</td>
                                                        <td>@item["Status_Comment"]</td>*@
                                                    <td>@item["Leave_Status"]</td>
                                                    <td><a class="btn btn-warning openAcceptModal" data-Sr="@item["Sr"]" data-bs-toggle="modal" data-bs-target="#AcceptModal"> Accept </a> | <a class="btn btn-danger openRejectModal" data-Sr="@item["Sr"]" data-bs-toggle="modal" data-bs-target="#RejectModal"> Reject </a></td>
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                            <!-- Start Accept Modal-->
                            <!-- Modal -->
                            <div class="modal fade" id="AcceptModal" tabindex="-1" aria-labelledby="AcceptModalLabel">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form id="AcceptLeaveForm" method="post">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="exampleModalLabel">Accept Leave</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>

                                            <div class="modal-body">
                                                <input readonly type="text" id="AcceptFormSrId" class="form-control" />
                                                <br />
                                                <label for="AcceptAdminCommentId" class="fw-bolder">Comment</label>
                                                <textarea class="form-control" id="AcceptAdminCommentId" name="AdminCommentAttribute" rows="3" cols="30"></textarea>
                                                <br />
                                                <label class="fw-bolder" for="StatusViaAdminId">Status Via Admin</label><br />
                                                <input type="radio" name="StatusViaAdminAttribute" value="Paid Leave" /><span> Paid Leave</span><br />
                                                <input type="radio" name="StatusViaAdminAttribute" value="Unpaid Leave" /><span> Unpaid Leave</span>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                <button type="submit" class="btn btn-success btn_Accept">Accept Leave</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <!-- End Accept Modal-->
                            <!-- Start Reject Modal-->
                            <div class="modal fade" id="RejectModal" tabindex="-1" aria-labelledby="RejectModalLabel">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form method="post">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="exampleModalLabel">Reject Leave</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <input readonly type="text" id="RejectFormSrId" class="form-control" />
                                                <br />

                                                <label for="RejectAdminCommentId" class="fw-bolder">Comment</label>
                                                <textarea class="form-control" id="RejectAdminCommentId" name="AdminCommentAttribute" rows="3" cols="30"></textarea>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                <button type="submit" class="btn btn-danger btn_Reject">Reject Leave</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <!-- End Reject Modal-->
                        </div>
                    </div>
                </div>
                <!-- End Pending Leaves-->
                <!-- Start Accepted Leaves-->
                <div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                    <div class="row">
                        <div class="col-sm-6">
                            <table class="table" id="mytable">
                                <thead class="table table-bordered table-success table-hover table-responsive">
                                    <tr>
                                        <th>Sr</th>
                                        <th>EmployeeId</th>
                                        <th>EmployeeName</th>
                                        <th>Leave_Subject</th>
                                        <th>Leave_Details</th>
                                        <th>From_Date</th>
                                        <th>To_Date</th>
                                        <th>Total_Days</th>
                                        <th>Added_On</th>
                                        <th>Admin Status</th>
                                        <th>Comment By Admin</th>
                                        <th>Leave_Status</th>
                                        @*<th>Action</th>*@

                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        foreach (System.Data.DataRow item in Model.Rows)
                                        {
                                            //if (item["Leave_Status"].ToString() == "Accepted")
                                            if (item["Leave_Status"].ToString().Equals("Accepted"))
                                            {
                                                <tr>
                                                    <td>@item["Sr"]</td>
                                                    <td>@item["EmployeeId"]</td>
                                                    <td>@item["EmployeeName"]</td>
                                                    <td>@item["Leave_Subject"]</td>
                                                    <td>@item["Leave_Details"]</td>
                                                    <td>@item["From_Date"]</td>
                                                    <td>@item["To_Date"]</td>
                                                    <td>@item["Total_Days"]</td>
                                                    <td>@item["Added_On"]</td>
                                                    <td>@item["Status_via_Admin"]</td>
                                                    <td>@item["Status_Comment"]</td>
                                                    <td>@item["Leave_Status"]</td>
                                                    @*<td><a class="btn btn-warning" href="/Home/GetLeaveById?OldLeaveId=@item["EmployeeId"]">Accept</a> | <a class="btn btn-danger" href="/Home/GetLeaveById?LeaveId=@item["EmployeeId"]">Reject</a></td>*@
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- End Accepted Leaves-->
                <!-- Start Rejected Leaves-->
                <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
                    <div class="row">
                        <div class="col-sm-6">
                            <table class="table" id="mytable">
                                <thead class="table table-bordered table-danger table-hover table-responsive">
                                    <tr>
                                        <th>Sr</th>
                                        <th>EmployeeId</th>
                                        <th>EmployeeName</th>
                                        <th>Leave_Subject</th>
                                        <th>Leave_Details</th>
                                        <th>From_Date</th>
                                        <th>To_Date</th>
                                        <th>Total_Days</th>
                                        <th>Added_On</th>
                                        <th>Admin Status</th>
                                        <th>Comment By Admin</th>
                                        <th>Leave_Status</th>
                                        @*<th>Action</th>*@

                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        foreach (System.Data.DataRow item in Model.Rows)
                                        {
                                            //if (item["Leave_Status"].ToString() == "Rejected")
                                            if (item["Leave_Status"].ToString().Equals("Rejected"))
                                            {
                                                <tr>
                                                    <td>@item["Sr"]</td>
                                                    <td>@item["EmployeeId"]</td>
                                                    <td>@item["EmployeeName"]</td>
                                                    <td>@item["Leave_Subject"]</td>
                                                    <td>@item["Leave_Details"]</td>
                                                    <td>@item["From_Date"]</td>
                                                    <td>@item["To_Date"]</td>
                                                    <td>@item["Total_Days"]</td>
                                                    <td>@item["Added_On"]</td>
                                                    <td>@item["Status_via_Admin"]</td>
                                                    <td>@item["Status_Comment"]</td>
                                                    <td>@item["Leave_Status"]</td>
                                                    @*<td><a class="btn btn-warning" href="/Home/GetLeaveById?OldLeaveId=@item["EmployeeId"]">Accept</a> | <a class="btn btn-danger" href="/Home/GetLeaveById?LeaveId=@item["EmployeeId"]">Reject</a></td>*@
                                                </tr>
                                            }

                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- End Rejected Leaves-->


            </div>
        }
        else
        {
            <div>No leaves Found</div>
        }
    }

</div>

<script>
    var AcceptSr = "";
    $(document).ready(function ()
    {
        
        // When clicking Accept link in table
        $(".openAcceptModal").click(function () {
           AcceptSr = $(this).data("sr");
            console.log("Sr Value:", AcceptSr);
            $("#AcceptFormSrId").val(AcceptSr);
        });
        

        $(".btn_Accept").click(function (event)
        {
            event.preventDefault()
            //var SelectedEmployeeId = $(this).parent().parent().find(".td_EmployeeId").text()
            //$("#AcceptFormSrId").val(SelectedEmployeeId)

            //var SelectedSr = $("#AcceptFormSrId").val()
            var SelectedSr = AcceptSr
            var AdminCommentVariable = $("#AcceptAdminCommentId").val()
            var StatusViaAdminVariable = $("input[name='StatusViaAdminAttribute']:checked").val()
            var token = $('input[name="__RequestVerificationToken"]').val();

            var hiddingRecordVariable = $(this).parent().parent()
            $.ajax({
                url: '/Home/AcceptLeave',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    AdminCommentToController: AdminCommentVariable,
                    StatusViaAdminToController: StatusViaAdminVariable,
                    SrToController: SelectedSr
                },
                success: function (responseVaribale)
                {
                    if (responseVaribale.result > 0)
                    {
                        hiddingRecordVariable.hide()
                        alert('Leave accepted Successfully.')
                    }
                    else
                    {
                        alert('Leave failed to process - AJAX msg.')
                    }
                },
                error: function()
                {
                    alert('Some Error occured in AJAX')
                }
            })
        })
    })
    $(document).ready(function ()
    {
        $("#RejectModal").on('show.bs.modal', function () {
            $(this).removeAttr('inert');
        });

        $("#RejectModal").on('hidden.bs.modal', function () {
            $(this).attr('inert', 'true');
        });

        var RejectSr = "";
        // When clicking Reject link in table
        $(".openRejectModal").click(function () {
            RejectSr = $(this).data("sr");
            console.log("Sr Value:", RejectSr);
            $("#RejectFormSrId").val(RejectSr);
        });

        

        $(".btn_Reject").click(function (event)
        {
            event.preventDefault()
            //var SelectedSr = $(this).parent().parent().find(".td_EmployeeId").text()
            //$("#RejectFormEmpSr").val(SelectedSr)

            //var SelectedSr = $("#RejectFormSrId").val()
            var SelectedSr = RejectSr
            var adminComment = $("#RejectAdminCommentId").val();
            var token = $('input[name="__RequestVerificationToken"]').val();
            var hiddingRecordVariable = $(this).parent().parent()
            $.ajax({
                url: '/Home/RejectLeave',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    SrToController: SelectedSr,
                    AdminCommentToController: adminComment },
                success: function (responseVaribale)
                {
                    if (responseVaribale > 0) {
                        hiddingRecordVariable.hide()
                        alert('Leave rejected Successfully.')
                    }
                    else
                    {
                        alert('Leave failed to process - AJAX msg.')
                    }
                }
            })
        })
    })
</script>




