
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/_EmployeeLayoutPage.cshtml";
}

<h2>Change Password</h2>

<div class="container">
    <div class="row py-2">
        <div class="col-sm-10 mx-auto">
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="row py-4">
                    <div class="col-sm-4 mx-auto">
                        <div class="card shadow-lg mx-auto border border-0">
                            <p class="text-center m-0 fs-4"> Change <b class="text-danger">Password</b></p>
                            <div class="form-floating m-3">
                                <input type="text" class="form-control" id="floatingInput" placeholder="name@example.com">
                                <label for="floatingInput">Enter your Employee ID</label>
                            </div>
                            <div class="form-floating m-3">
                                <input type="password" class="form-control" id="floatingInput" placeholder="name@example.com">
                                <label for="floatingInput">Enter your New Password</label>
                            </div>
                            <button class="btn bg-mycolor mx-3 mb-3" type="submit">Update Password</button>
                        </div>
                    </div>
                </div>
            </form>
            
        </div>
    </div>
</div>

