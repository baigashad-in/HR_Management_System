
@{
    ViewBag.Title = "ForgotPassword";
    Layout = "~/Views/Shared/_EmployeeLayoutPage.cshtml";
}

<h2>Forgot Password</h2>

<div class="container-fluid">
    <div class="row d-grid justify-content-center">
        <div class="col-sm1-12 shadow-lg p-4 m-5 rounded-4">
            <form method="post">
                @Html.AntiForgeryToken()
                <label for="EmployeeIdVerifyId" class="fw-bolder">Enter Your EmployeeId</label>
                <input class="form-control" type="text" name="EmployeeIdVerifyAttribute" id="EmployeeIdVerifyId"/>
                <br />
                <input type="submit" class="btn mycolor1" value="Send OTP" />
            </form>
        </div>
    </div>
</div>

