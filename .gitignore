# Environment and secrets
# ======================
.env
appsettings.Development.json
appsettings.Local.json
Web.config   # Only if it contains passwords or connection strings

# ======================
# Temporary / cache files
# ======================
*.log
*.tmp
*.cache
*.DS_Store

# ======================
# Roslyn / compiler tools
# ======================
/bin/roslyn/

# Visual Studio IDE folder
.vs/